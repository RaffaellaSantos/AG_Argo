import numpy as np
import random
import copy
import matplotlib.pyplot as plt
import matplotlib.animation as animation

print("=== CONFIGURAÇÃO DO PROJETO ===")

comprimento = float(input("Comprimento da embarcação (cm): "))
fator_CL = float(input("Fator C/L (3.2 a 4.0): "))
massa_X = float(input("Massa X dos containers (g): "))

NUM_CONTAINERS = 24
TAM_POPULACAO = 80
NUM_GERACOES = 120

largura = comprimento / fator_CL

print(f"\nLargura estimada da embarcação: {largura:.2f} cm")

# massas reais
massas = [massa_X]*12 + [2*massa_X]*12
random.shuffle(massas)

# barco com massas
barco_inicial = np.zeros((2,4,4))
idx = 0
for z in range(2):
    for y in range(4):
        for x in range(4):
            if z == 0 or y < 2:
                barco_inicial[z,y,x] = massas[idx]
                idx += 1

pier_inicial = np.zeros((2,2,2))

class BalsaAG:
    def __init__(self):
        self.tam_cromossomo = 40
        self.p_mutacao = 0.1
        self.p_crossover = 0.85
        self.populacao = [self.gerar_cromossomo() for _ in range(TAM_POPULACAO)]
        self.historico_melhor = []
        self.historico_media = []
        self.historico_barcos = []

    def gerar_cromossomo(self):
        return np.array([
            [random.randint(0,3), random.randint(0,3),
             random.randint(0,1), random.randint(0,1)]
            for _ in range(self.tam_cromossomo)
        ])

    def topo(self, matriz, y, x):
        for z in range(1,-1,-1):
            if matriz[z,y,x] > 0:
                return z
        return -1

    def livre(self, matriz, y, x):
        for z in range(2):
            if matriz[z,y,x] == 0:
                return z
        return -1

    def estabilidade(self, barco):
        total = np.sum(barco)
        if total == 0:
            return 0

        soma = 0
        for z in range(2):
            for y in range(4):
                for x in range(4):
                    soma += barco[z,y,x] * x

        centro = soma / total
        return abs(centro - 1.5)

    def simular(self, crom):
        barco = copy.deepcopy(barco_inicial)
        pier = copy.deepcopy(pier_inicial)
        custo = 0

        for gene in crom:
            by,bx,py,px = gene
            zb = self.topo(barco, by, bx)
            zp = self.livre(pier, py, px)

            if zb == -1 or zp == -1:
                custo += 200
                continue

            peso = barco[zb,by,bx]
            barco[zb,by,bx] = 0
            pier[zp,py,px] = peso

            custo += abs(by-py) + abs(bx-px)
            custo += self.estabilidade(barco)*50

        custo += np.sum(barco>0)*500
        return barco, 10000/(1+custo)

    def fitness(self, crom):
        _, fit = self.simular(crom)
        return fit

    def selecao(self, fits):
        i,j = random.sample(range(TAM_POPULACAO),2)
        return self.populacao[i] if fits[i] > fits[j] else self.populacao[j]

    def crossover(self, p1, p2):
        if random.random() < self.p_crossover:
            pt = random.randint(1,self.tam_cromossomo-2)
            return (np.concatenate((p1[:pt],p2[pt:])),
                    np.concatenate((p2[:pt],p1[pt:])))
        return p1.copy(), p2.copy()

    def mutacao(self, ind):
        for i in range(self.tam_cromossomo):
            if random.random() < self.p_mutacao:
                ind[i] = [
                    random.randint(0,3),
                    random.randint(0,3),
                    random.randint(0,1),
                    random.randint(0,1)
                ]

    def executar(self):
        melhor_global = None

        for g in range(NUM_GERACOES):
            fits = [self.fitness(i) for i in self.populacao]
            idx = np.argmax(fits)
            melhor = self.populacao[idx]

            barco_final, _ = self.simular(melhor)

            self.historico_melhor.append(np.max(fits))
            self.historico_media.append(np.mean(fits))
            self.historico_barcos.append(barco_final.copy())

            print(f"Geração {g+1} | Melhor {fits[idx]:.2f}")

            nova = [melhor.copy()]
            while len(nova) < TAM_POPULACAO:
                p1 = self.selecao(fits)
                p2 = self.selecao(fits)
                f1,f2 = self.crossover(p1,p2)
                self.mutacao(f1)
                self.mutacao(f2)
                nova.append(f1)
                if len(nova)<TAM_POPULACAO:
                    nova.append(f2)

            self.populacao = nova
            melhor_global = melhor

        return melhor_global

ag = BalsaAG()
ag.executar()

plt.plot(ag.historico_melhor,label="Melhor")
plt.plot(ag.historico_media,label="Média")
plt.legend()
plt.grid()
plt.show()

fig, ax = plt.subplots()

def update(frame):
    ax.clear()
    barco = ag.historico_barcos[frame]

    for z in range(2):
        for y in range(4):
            for x in range(4):
                peso = barco[z,y,x]
                if peso > 0:
                    cor = 'red' if peso == massa_X else 'blue'
                else:
                    cor = 'lightgray'

                ax.scatter(x, y+z*5, s=1200, c=cor, edgecolors='black')

    ax.set_title(f"Geração {frame+1}")
    ax.set_xlim(-1,5)
    ax.set_ylim(-1,10)

ani = animation.FuncAnimation(fig, update, frames=len(ag.historico_barcos), interval=500)
ani.save("descarregamento_balsa.gif", writer="pillow")
plt.show()
